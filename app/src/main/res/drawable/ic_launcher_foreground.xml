<?xml version="1.0" encoding="utf-8"?>
<!-- Tofu mascot — the same isometric block used as the web app's welcome /
     apple-touch icon, re-authored as a VectorDrawable so the launcher icon
     scales crisply at every density. Drawn in the source 180-space and scaled
     into the adaptive-icon safe zone by the enclosing <group>. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <group
        android:scaleX="0.5"
        android:scaleY="0.5"
        android:translateX="8.75"
        android:translateY="9.25">

        <!-- top face -->
        <path android:pathData="M86,26 L36,54 L91,90 L147,59 Z">
            <aapt:attr name="android:fillColor">
                <gradient android:type="linear"
                    android:startX="36" android:startY="26"
                    android:endX="91.5" android:endY="90">
                    <item android:offset="0" android:color="#FFFEF8EC"/>
                    <item android:offset="1" android:color="#FFFDF2D7"/>
                </gradient>
            </aapt:attr>
        </path>

        <!-- front-left face -->
        <path android:pathData="M36,54 L34,119 L97,153 L91,90 Z">
            <aapt:attr name="android:fillColor">
                <gradient android:type="linear"
                    android:startX="34" android:startY="54"
                    android:endX="46.6" android:endY="153">
                    <item android:offset="0" android:color="#FFFDF4DC"/>
                    <item android:offset="1" android:color="#FFF5E8C8"/>
                </gradient>
            </aapt:attr>
        </path>

        <!-- right face -->
        <path android:pathData="M91,90 L97,153 L145,125 L147,59 Z">
            <aapt:attr name="android:fillColor">
                <gradient android:type="linear"
                    android:startX="91" android:startY="59"
                    android:endX="147" android:endY="124.8">
                    <item android:offset="0" android:color="#FFECDCC0"/>
                    <item android:offset="1" android:color="#FFDCC8A4"/>
                </gradient>
            </aapt:attr>
        </path>

        <!-- block outline -->
        <path android:pathData="M86,26 L36,54 L34,119 L97,153 L145,125 L147,59 Z"
            android:strokeColor="#FF1A1520"
            android:strokeWidth="3.2"
            android:strokeLineJoin="round"/>

        <!-- top-face highlight -->
        <path android:pathData="M53,38 L74,31 L80,34 L59,41 Z"
            android:fillColor="#FFFFFFFF"
            android:fillAlpha="0.5"/>

        <!-- left eye -->
        <path android:pathData="M44,80 L59,80 L59,99 L44,99 Z"
            android:fillColor="#FF1A1520"/>
        <path android:pathData="M52,81 L57,81 L57,88 L52,88 Z"
            android:fillColor="#FFFFFFFF" android:fillAlpha="0.92"/>
        <path android:pathData="M45,89 L48,89 L48,93 L45,93 Z"
            android:fillColor="#FFFFFFFF" android:fillAlpha="0.45"/>

        <!-- right eye -->
        <path android:pathData="M73,93 L88,93 L88,114 L73,114 Z"
            android:fillColor="#FF1A1520"/>
        <path android:pathData="M81,94 L86,94 L86,101 L81,101 Z"
            android:fillColor="#FFFFFFFF" android:fillAlpha="0.92"/>
        <path android:pathData="M74,104 L77,104 L77,109 L74,109 Z"
            android:fillColor="#FFFFFFFF" android:fillAlpha="0.45"/>

        <!-- mouth -->
        <path android:pathData="M57,113 Q68,121 78,113"
            android:strokeColor="#FF1A1520"
            android:strokeWidth="1.5"
            android:strokeLineCap="round"
            android:strokeAlpha="0.45"/>

        <!-- cheeks -->
        <path android:pathData="M39.5,103 a5.5,4 0 1,0 11,0 a5.5,4 0 1,0 -11,0 Z"
            android:fillColor="#FFFFAAA2" android:fillAlpha="0.5"/>
        <path android:pathData="M78,120 a6,4 0 1,0 12,0 a6,4 0 1,0 -12,0 Z"
            android:fillColor="#FFFEACA5" android:fillAlpha="0.5"/>
    </group>
</vector>
